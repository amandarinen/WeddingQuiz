@inherits LayoutComponentBase
@using MudBlazor

<MudLayout>

    <!-- Topbar -->
    <MudAppBar Elevation="0" Style="background-color:#FFFFFF; color:#3A3A3A;">
        <MudText Typo="Typo.h6">💍 WeddingQuiz</MudText>
        <MudSpacer />

        <!-- Home -->
        <MudButton Link=" " Variant="Variant.Text" Style="text-transform:none;">Hem</MudButton>

        <!-- Dropdown / Quiz -->
        <MudMenu Label="Quiz" Color="Color.Secondary" Variant="Variant.Text" Style="text-transform:none;">
            <MudMenuItem Href="quiz">Möhippa/Svensexa</MudMenuItem>
            <MudMenuItem Href="della-quiz">Quiz om Della</MudMenuItem>
            <MudMenuItem Href="rasmus-quiz">Quiz om Rasmus</MudMenuItem>
        </MudMenu>
    </MudAppBar>

    <!-- Main content -->
    <MudMainContent Class="pa-6">
        @Body
    </MudMainContent>

</MudLayout>