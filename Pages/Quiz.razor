@page "/quiz"
@using WeddingQuiz.Models

<PageTitle>Quiz</PageTitle>

<MudPaper Class="mx-auto pa-6" Style="max-width:700px; text-align:center; border-radius:20px; background-color:var(--sage-light);">

    <MudText Typo="Typo.h2" Class="mb-6" Style="color:var(--dusty-rose); font-size:2.5rem; font-weight:700;">
        Della & Rasmus Wedding Quiz
    </MudText>

    <MudText Typo="Typo.h5" Class="mb-6">
        Hur väl känner du brudparet?
    </MudText>

    @if (showResult)
    {
        <MudCard Class="pa-6 mt-4" Style="border-radius:20px; display:flex; flex-direction:column; align-items:center;">
            <MudText Typo="Typo.h4" Class="mb-3">Quiz Avslutad!</MudText>
            <MudText Typo="Typo.h5" Class="mb-4">Din poäng: @score / @questions.Count</MudText>

            <div style="display:flex; justify-content:center; width:100%; min-height:60px;">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Style="width:220px; height:50px; border-radius:16px;"
                           OnClick="RestartQuiz">
                    Spela igen
                </MudButton>
            </div>
        </MudCard>
    }
    else
    {
        <MudText Typo="Typo.h6" Class="mb-3">
            Fråga @(@currentQuestion + 1) / @questions.Count
        </MudText>

        <MudCard Class="pa-4 mb-4" Style="border-radius:20px; display:flex; flex-direction:column; align-items:center;">
            <MudText Typo="Typo.h6" Class="mb-3">@questions[currentQuestion].Question</MudText>

            <MudGrid Class="mt-3 mb-4" Spacing="2">
                @foreach (var answer in questions[currentQuestion].Answers)
                {
                    <MudItem xs="12" sm="6" Class="d-flex justify-center">
                        <MudButton Variant="Variant.Filled"
                                   Color="@GetButtonColor(answer)"
                                   Class="ma-1"
                                   Disabled="@answered"
                                   Style="width: 220px; min-height: 60px; padding:10px; font-size:0.9rem; font-weight:600; border-radius:16px; white-space: normal; line-height:1.3; text-align:center;"
                                   OnClick="@(() => SelectAnswer(answer))">
                            @answer
                        </MudButton>
                    </MudItem>
                }
            </MudGrid>

            @if (answered)
            {
                <MudText Typo="Typo.h6" Class="mb-3" Color="@feedbackColor">
                    @feedbackMessage
                </MudText>
            }
            else
            {
                <div style="height:2rem;"></div>
            }

            <div style="display:flex; justify-content:center; width:100%; min-height:60px; margin-top:1rem;">
                @if (answered)
                {
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Style="width:180px; height:50px; border-radius:20px;"
                               OnClick="NextQuestion">
                        Nästa fråga
                    </MudButton>
                }
            </div>
        </MudCard>
    }
</MudPaper>

@code {
    int currentQuestion = 0;
    int score = 0;
    bool answered = false;
    bool showResult = false;
    string feedbackMessage = "";
    Color feedbackColor = Color.Default;
    string selectedAnswer = "";

    List<QuizQuestion> questions = new()
    {
        new QuizQuestion
    {
        Question = "Vad var deras första dejt?",
        CorrectAnswer = "Promenad i –20 grader",
        Answers = new() { "Bio och middag", "Promenad i –20 grader", "Picknick i 30+ grader", "Middag hemma och film" }
    },
    new QuizQuestion
    {
        Question = "Vem är mest morgontrött?",
        CorrectAnswer = "Della",
        Answers = new() { "Tor", "Rasmus", "Ingen", "Della" }
    },
    new QuizQuestion
    {
        Question = "Vem är mest impulsiv?",
        CorrectAnswer = "Della",
        Answers = new() { "Della", "Rasmus", "Båda", "Ingen" }
    },
    new QuizQuestion
    {
        Question = "Vilken var deras bästa resa tillsammans?",
        CorrectAnswer = "Lissabon",
        Answers = new() { "Budapest", "Lissabon", "Kroatien", "Skåne" }
    },
    new QuizQuestion
    {
        Question = "Vad tittar de helst på under en filmkväll?",
        CorrectAnswer = "Komedi/Action",
        Answers = new() { "Skräck/Thriller", "Komedi/Action", "Dokumentär/Deckare", "Drama/Sci-Fi" }
    },
    new QuizQuestion
    {
        Question = "Vad glömmer de oftast (R= Rasmus, D= Della)?",
        CorrectAnswer = "D: Glasögonen / R: Bilnyckeln",
        Answers = new() { "D: Mobilen / R: Mössan", "D: Halsduk / R: Plånbok", "D: Glasögonen / R: Bilnyckeln", "D: Tjocktröja / R: Solglasögon" }
    },
    new QuizQuestion
    {
        Question = "Hur ser deras perfekta dejt ut?",
        CorrectAnswer = "Promenad + tidig middag",
        Answers = new() { "Brunch + spa", "Promenad + tidig middag", "Sen middag + klubba", "Film + snabbmat" }
    },
     new QuizQuestion
    {
        Question = "Vem sa 'jag älskar dig' först?",
        CorrectAnswer = "Della",
        Answers = new() { "Della", "Rasmus", "Båda samtidigt", "Ingen än" }
    },
    new QuizQuestion
    {
        Question = "Vilken musik spelas oftast hemma hos Rasmus och Della?",
        CorrectAnswer = "Lounge",
        Answers = new() { "Rock", "Lounge", "Hip hop", "EDM" }
    },
    new QuizQuestion
    {
        Question = "Vem gör flest romantiska gester?",
        CorrectAnswer = "Rasmus",
        Answers = new() { "Della", "Rasmus", "Båda", "Ingen" }
    },
    new QuizQuestion
    {
        Question = "Vem stänger fönstret först?",
        CorrectAnswer = "Della: 'Det är för kallt!'",
        Answers = new() { "Della: 'Det är för kallt!'", "Rasmus: 'Du släpper ut värmen!'", "Tor: 'Voff voff (jag såg en ekorre!)'", "Grannen: 'Ni väsnas för mycket!'" }
    },
    new QuizQuestion
    {
        Question = "Vem snarkar mest?",
        CorrectAnswer = "Rasmus",
        Answers = new() { "Della", "Tor", "Alla tre", "Rasmus" }
    },
    new QuizQuestion
    {
        Question = "Du ska bjuda Rasmus och Della på middag! Vad lagar du?",
        CorrectAnswer = "Tacos",
        Answers = new() { "Skaldjursplatå", "Grillat", "Löksoppa", "Tacos" }
    },
    new QuizQuestion
    {
        Question = "Vilken take-away beställer de oftast?",
        CorrectAnswer = "Pizza",
        Answers = new() { "Sushi", "Thai", "Pizza", "Indiskt" }
    },
    new QuizQuestion
    {
        Question = "Vem är mest tävlingsinriktad?",
        CorrectAnswer = "Della",
        Answers = new() { "Della", "Rasmus", "Båda", "Ingen" }
    }
    };

    void SelectAnswer(string answer)
    {
        if (answered) return;

        selectedAnswer = answer;
        answered = true;

        if (answer == questions[currentQuestion].CorrectAnswer)
        {
            score++;
            feedbackMessage = "Rätt! Wohoo! ";
            feedbackColor = Color.Success;
        }
        else
        {
            feedbackMessage = $"Fel... Rätt svar: {questions[currentQuestion].CorrectAnswer}";
            feedbackColor = Color.Error;
        }
    }

    void NextQuestion()
    {
        answered = false;
        selectedAnswer = "";
        feedbackMessage = "";

        if (currentQuestion < questions.Count - 1)
        {
            currentQuestion++;
        }
        
        else
        {
            showResult = true;
        }
    }

    void RestartQuiz()
    {
        currentQuestion = 0;
        score = 0;
        answered = false;
        showResult = false;
        selectedAnswer = "";
        feedbackMessage = "";
    }

    Color GetButtonColor(string answer)
    {
        if (!answered) return Color.Primary;
        if (answer == questions[currentQuestion].CorrectAnswer) return Color.Success;
        if (answer == selectedAnswer) return Color.Error;
        return Color.Primary;
    }
}
