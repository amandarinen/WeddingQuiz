@page "/"

<PageTitle>Home</PageTitle>

<MudPaper Class="mx-auto pa-6" Style="max-width:700px; text-align:center; border-radius:20px; background-color:var(--sage-light);">

    <MudText Typo="Typo.h2" Class="mb-6" Style="color:var(--dusty-rose); font-size:3rem; font-weight:700;">
        Välkommen till Della & Rasmus Wedding Quiz!
    </MudText>

    <MudText Typo="Typo.body1" Class="mb-4">
        Våra älskade vänner ska äntligen gifta sig!
        Vad är då härligare än ett litet quiz om vårt favoritpar?
    </MudText>

    <MudText Typo="Typo.body2" Class="mb-6">
        Svara på några frågor och se hur väl du känner dem!
    </MudText>

    <MudStack Spacing="2" Class="d-flex flex-column align-items-center">
        <MudButton Href="quiz" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Style="border-radius:16px; width: 250px;">
            Quiz för möhippa/svensexa
        </MudButton>

        <MudButton Href="della-quiz" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Style="border-radius:16px; width: 250px;">
            Quiz om Della
        </MudButton>

        <MudButton Href="rasmus-quiz" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Style="border-radius:16px; width: 250px;">
            Quiz om Rasmus
        </MudButton>
    </MudStack>

</MudPaper>